def dfs_limitado(grafo, inicio, limite):
    visitados =[]
    pila = [(inicio, 0)] #tupla de (nodo, profundidad actual)

    while pila:
        nodo, profundidad = pila.pop() #Desempaquetado de la tupla

        if nodo not in visitados:
            visitados.append(nodo)
            print(f"Visitados: {nodo} | Profundidad: {profundidad} | Pila: {pila}")

            if profundidad < limite: # Solo seguimos la busqueda si no superarmos el limite
                for vecino in grafo[nodo]:
                    if vecino not in visitados:
                        pila.append((vecino, profundidad + 1)) #Subimos la profundidad en 1


    return visitados

# Definicion de grafo utilizado
grafo = {
    'A':['B', 'C'],
    'B':['D', 'E'],
    'C':['F'],
    'D':[], 'E':[], 'F':[],
}

print("---Limite 1---")
dfs_limitado(grafo, 'A', 1)

print("\n---Limite 2---")
dfs_limitado(grafo, 'A', 2)